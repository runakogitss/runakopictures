  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/japantravel",
      "destination": "/public/japantravel.html"
    },
    {
      "source": "/kotalama", 
